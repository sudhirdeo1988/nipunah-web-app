# Copy to `.env` or `.env.local` and adjust. Next.js loads `.env`, `.env.local`, `.env.development`, etc. when you run `npm run dev` / `npm run build` / `npm start`.

API_BASE_URL=http://139.59.22.7:8080/api

# reCAPTCHA v2 (use a matching site + secret pair from Google Admin).
# Placeholder keys like 6Lcxxxxxxxx will not load the widget; use real keys or Google’s documented test keys for local dev.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lcxxxxxxxx
RECAPTCHA_SECRET_KEY=6Lcxxxxxxxx
