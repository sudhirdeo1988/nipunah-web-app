# Copy to `.env` or `.env.local` and adjust. Next.js loads `.env`, `.env.local`, `.env.development`, etc. when you run `npm run dev` / `npm run build` / `npm start`.

API_BASE_URL=http://139.59.22.7:8080/api

# reCAPTCHA v2 Checkbox (site + secret must be a matching pair from https://www.google.com/recaptcha/admin).
# Add your domains (e.g. localhost, 127.0.0.1, production host) under the key settings.
# Restart `npm run dev` after changing these values.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here
